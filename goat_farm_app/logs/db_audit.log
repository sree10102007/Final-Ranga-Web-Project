            SELECT tag_id as tag_no, date_of_sale as date, 'income' as category, sold_price as amount FROM sales_records WHERE date_of_sale IS NOT NULL
            UNION ALL
            SELECT tag_no, COALESCE(med1_date, vac1_date) as date, 'expense' as category, COALESCE(medicine_amount, 0) + COALESCE(vaccine_amount, 0) as amount FROM medicine_records WHERE (med1_date IS NOT NULL OR vac1_date IS NOT NULL)
            UNION ALL
            SELECT tag_id as tag_no, expired_date as date, 'expense' as category, COALESCE(current_value, 0) as amount FROM mortality_records WHERE expired_date IS NOT NULL
            UNION ALL
            SELECT tag_id as tag_no, insurance_claim_date as date, 'income' as category, COALESCE(claim_amount, 0) as amount FROM mortality_records WHERE insurance_claim_date IS NOT NULL
            UNION ALL
            SELECT tag_no, purchase_date as date, 'expense' as category, COALESCE(purchase_amount, 0) as amount FROM master_records WHERE purchase_date IS NOT NULL
        )
        SELECT m.tag_no as tag_number, 
               m.status,
               m.dob,
               COUNT(a.amount) as total_records,
               COALESCE(SUM(CASE WHEN a.category = 'income' THEN a.amount ELSE 0 END), 0) as total_income,
               COALESCE(SUM(CASE WHEN a.category = 'expense' THEN a.amount ELSE 0 END), 0) as total_expense
        FROM master_records m
        LEFT JOIN AllRecords a ON m.tag_no = a.tag_no
        GROUP BY m.tag_no, m.status, m.dob
        ORDER BY CAST(m.tag_no AS INTEGER) ASC | Param Count: 0
