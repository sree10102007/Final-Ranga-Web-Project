# Database Connection Configuration
# Copy this file to '.env' and modify with your actual PostgreSQL connection settings.

# If DATABASE_URL is set, it takes precedence and is used as the connection string
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goat_farm

DB_HOST=localhost
DB_PORT=5432
DB_NAME=goat_farm
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer
