# Database Connection Configuration
# Copy this file to '.env' and modify with your actual PostgreSQL connection settings.

# If DATABASE_URL is set, it takes precedence and is used as the connection string
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goat_farm

DB_HOST=your_database_host
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSLMODE=prefer
SECRET_KEY=your_secret_key_here
FLASK_ENV=production

# Admin Initial Credentials
ADMIN_PASSWORD=your_secure_admin_password_here

# Rate Limiter Backend Store (e.g. redis://localhost:6379/0 or memory://)
LIMITER_STORAGE_URI=memory://

